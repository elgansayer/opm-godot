root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cpp,h,hpp}]
indent_style = tab
indent_size = 4

[*.{gd,tscn,tres,godot,gdextension}]
indent_style = tab
indent_size = 4

[*.{py,json,yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[SConstruct]
indent_style = space
indent_size = 4

[SConscript]
indent_style = space
indent_size = 4
