{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-cmake/${presetName}",
      "cacheVariables": {
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "linux-debug",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "linux",
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "linux-release",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "linux",
        "OPM_BUILD_VARIANT": "release"
      }
    },
    {
      "name": "windows-debug",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "windows",
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "windows-release",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "windows",
        "OPM_BUILD_VARIANT": "release"
      }
    },
    {
      "name": "macos-debug",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "macos",
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "macos-release",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "macos",
        "OPM_BUILD_VARIANT": "release"
      }
    },
    {
      "name": "web-debug",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "web",
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "web-release",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "web",
        "OPM_BUILD_VARIANT": "release"
      }
    },
    {
      "name": "android-debug",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "android",
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "android-release",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "android",
        "OPM_BUILD_VARIANT": "release"
      }
    },
    {
      "name": "ios-debug",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "ios",
        "OPM_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "ios-release",
      "inherits": ["base"],
      "cacheVariables": {
        "OPM_TARGET_PLATFORM": "ios",
        "OPM_BUILD_VARIANT": "release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug-engine",
      "configurePreset": "linux-debug",
      "targets": ["opm-engine"]
    },
    {
      "name": "linux-release-engine",
      "configurePreset": "linux-release",
      "targets": ["opm-engine"]
    },
    {
      "name": "web-debug-engine",
      "configurePreset": "web-debug",
      "targets": ["opm-engine"]
    },
    {
      "name": "web-release-engine",
      "configurePreset": "web-release",
      "targets": ["opm-engine"]
    },
    {
      "name": "linux-debug-export",
      "configurePreset": "linux-debug",
      "targets": ["opm-export"]
    },
    {
      "name": "linux-release-export",
      "configurePreset": "linux-release",
      "targets": ["opm-export"]
    },
    {
      "name": "windows-debug-export",
      "configurePreset": "windows-debug",
      "targets": ["opm-export"]
    },
    {
      "name": "windows-release-export",
      "configurePreset": "windows-release",
      "targets": ["opm-export"]
    },
    {
      "name": "macos-debug-export",
      "configurePreset": "macos-debug",
      "targets": ["opm-export"]
    },
    {
      "name": "macos-release-export",
      "configurePreset": "macos-release",
      "targets": ["opm-export"]
    },
    {
      "name": "web-debug-export",
      "configurePreset": "web-debug",
      "targets": ["opm-web-export"]
    },
    {
      "name": "web-release-export",
      "configurePreset": "web-release",
      "targets": ["opm-web-export"]
    },
    {
      "name": "android-release-export",
      "configurePreset": "android-release",
      "targets": ["opm-export", "opm-sign-android"]
    },
    {
      "name": "ios-release-export",
      "configurePreset": "ios-release",
      "targets": ["opm-export", "opm-sign-ios"]
    }
  ]
}
